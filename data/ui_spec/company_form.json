{
  "title": "Executive Opportunity Scorer",
  "description": "Quick triage for a startup opportunity. Manual entry is limited to a few facts a human can gather quickly; the rest is reserved for future automated research.",
  "sections": [
    {
      "id": "quick_triage",
      "title": "Quick Triage",
      "fields": [
        {
          "id": "company_name",
          "label": "Company name",
          "type": "text",
          "required": true,
          "placeholder": "Example: monday.com",
          "help": "The company being evaluated."
        },
        {
          "id": "company_url",
          "label": "Company URL",
          "type": "text",
          "required": false,
          "default": "",
          "placeholder": "https://company.com or LinkedIn URL",
          "help": "Optional starting point for future automated research."
        },
        {
          "id": "snapshot_date",
          "label": "Snapshot date",
          "type": "text",
          "required": false,
          "ui_hidden": true,
          "help": "Defaults to the current timestamp."
        },
        {
          "id": "company_stage",
          "label": "Latest funding round",
          "type": "select",
          "required": false,
          "default": "",
          "options": ["", "Pre-seed", "Seed", "Series A", "Series B", "Series C", "Series D", "Growth", "Public"],
          "help": "Best known funding round. Leave blank if unknown."
        },
        {
          "id": "team_size",
          "label": "Approximate total employee count",
          "type": "number",
          "required": false,
          "default": null,
          "help": "Approximate total employee count."
        },
        {
          "id": "current_engineering_leadership",
          "label": "Current engineering leadership",
          "type": "multiselect",
          "required": false,
          "default": [],
          "options": ["Co-Founder & CTO", "CTO", "VP R&D", "VP Engineering", "Head of R&D", "Head of Engineering"],
          "help": "Select one or more leadership titles that already exist."
        }
      ]
    },
    {
      "id": "notes",
      "title": "Optional Notes",
      "fields": [
        {
          "id": "source_urls_text",
          "label": "Source links",
          "type": "textarea",
          "required": false,
          "default": "",
          "placeholder": "Paste 1-3 URLs, one per line",
          "help": "Optional links for later verification or future automated research."
        }
      ]
    },
    {
      "id": "automation_defaults",
      "title": "Automation Defaults",
      "fields": [
        {
          "id": "approx_rd_size",
          "label": "Approx R&D size",
          "type": "number",
          "required": false,
          "default": null,
          "ui_hidden": true,
          "help": "Reserved for future automation."
        },
        {
          "id": "existing_exec_layer",
          "label": "Existing executive layer",
          "type": "text",
          "required": false,
          "default": "",
          "ui_hidden": true,
          "help": "Derived from selected leadership roles."
        },
        {
          "id": "hiring_open_roles",
          "label": "Open roles",
          "type": "number",
          "required": false,
          "default": null,
          "ui_hidden": true,
          "help": "Reserved for future automation."
        },
        {
          "id": "engineering_roles_open",
          "label": "Engineering open roles",
          "type": "number",
          "required": false,
          "default": null,
          "ui_hidden": true,
          "help": "Reserved for future automation."
        },
        {
          "id": "geography",
          "label": "Geography",
          "type": "text",
          "required": false,
          "default": "Israel",
          "ui_hidden": true,
          "help": "V1 supports Israel only."
        },
        {
          "id": "category",
          "label": "Category",
          "type": "text",
          "required": false,
          "default": "SaaS",
          "ui_hidden": true,
          "help": "V1 supports SaaS only."
        },
        {
          "id": "is_gray_area",
          "label": "Gray-area company",
          "type": "boolean",
          "required": false,
          "default": false,
          "ui_hidden": true,
          "help": "Optional override for excluded sectors."
        }
      ]
    }
  ]
}
